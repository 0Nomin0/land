# Скопируй в .env.local и заполни

# Какой AI-провайдер использовать: gemini (бесплатный) или anthropic
AI_PROVIDER=gemini

# Gemini — бесплатный ключ: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash

# Anthropic (Claude) — если AI_PROVIDER=anthropic. Ключ: https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5

# Картинки к текстам. Без ключа работает фолбэк Openverse (реальные фото, без ключа).
# Для лучшего качества — бесплатный ключ Unsplash: https://unsplash.com/developers
# UNSPLASH_ACCESS_KEY=...

# Секрет для сессий (любая длинная случайная строка)
SESSION_SECRET=change-me-to-a-long-random-string
# Путь к файлу SQLite
DATABASE_PATH=./data/app.db
